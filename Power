    renderMessages(cached);
    document.getElementById('messagesContainer').scrollTop = 99999;

    await db.collection('chats').doc(currentChatId).collection('messages').add(msg);
    
    
    
    // Notify the other person
    const otherUserId = currentChatUser?.id;
    if (otherUserId && !currentChatUser?.isGroup) {
        sendNotification(otherUserId, 'message', {
            title: `New message from ${currentUser.name}`,
            body: text || '📎 Media'
        });
    }
    let lastMsgPreview = text || '';
if (!lastMsgPreview && imgs.length) lastMsgPreview = '📷 Photo';
else if (!lastMsgPreview && docs.length) lastMsgPreview = '📄 Document';
else if (!lastMsgPreview && vids.length) lastMsgPreview = '🎥 Video';
else if (!lastMsgPreview) lastMsgPreview = '📎 Media';
await db.collection('chats').doc(currentChatId).update({ lastMessage: lastMsgPreview, lastMessageTime: Date.now() });
}

