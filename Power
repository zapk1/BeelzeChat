    const docs = selectedFiles.filter(f => f.type === 'document');
    if (docs.length) msg.files = docs;
    const vids = selectedFiles.filter(f => f.type === 'video');
    if (vids.length) msg.video = vids[0];

    input.value = '';
    input.style.height = 'auto';
    selectedFiles = [];
    renderUploadPreview();

