async function postComment(postId, text) {
    if (!text) return;
    const ref = db.collection('posts').doc(postId);
    const snap = await ref.get();
    const newComment = { userId: currentUser.id, text, timestamp: Date.now() };
    const comments = [...(snap.data().comments || []), newComment];
    await ref.update({ comments });
    showToast('success', 'Posted!', 'Comment added');
    // Notify post owner
    const pSnap = await db.collection('posts').doc(postId).get();
    if (pSnap.exists) {
        sendNotification(pSnap.data().userId, 'comment', {
            title: `${currentUser.name} commented on your post`,
            body: text.substring(0, 60),
            postId
        });
    }

    // Add comment in-place without reloading
    const commentsList = document.getElementById(`comments-list-${postId}`);
    const inp = document.querySelector(`.comment-input[data-postid="${postId}"]`);
    if (commentsList) {
        const html = renderCommentHTML(newComment, postId, allUsers);
        commentsList.insertAdjacentHTML('beforeend', html);
        lucide.createIcons();
    }
    if (inp) inp.value = '';

    // Update comment count badge
    const commentBtn = document.querySelector(`.post-action-btn[data-postid="${postId}"][data-action="comment"] span`);
    if (commentBtn) commentBtn.textContent = formatCount(comments.length);
}

function getTimeAgo(ts) {
    if (!ts) return '';
    const s = Math.floor((Date.now() - ts) / 1000);
    if (s < 60) return 'Just now';
    const m = Math.floor(s / 60);
    if (m < 60) return `${m}m ago`;
    const h = Math.floor(m / 60);
    if (h < 24) return `${h}h ago`;
    return `${Math.floor(h / 24)}d ago`;
}



function formatCount(num) {
    if (num >= 1000000) return (num / 1000000).toFixed(1).replace('.0', '') + 'M';
    if (num >= 1000) return (num / 1000).toFixed(1).replace('.0', '') + 'K';
    return num.toString();
}


async function togglePostLike(postId) {
    const ref = db.collection('posts').doc(postId);
    const snap = await ref.get();
    const d = snap.data();
    const lb = d.likedBy || [];
    const liked = lb.includes(currentUser.id);
    const newLb = liked ? lb.filter(i => i !== currentUser.id) : [...lb, currentUser.id];
    const newRealLikes = liked ? Math.max((d.realLikes || 1) - 1, 0) : (d.realLikes || 0) + 1;
    await ref.update({ realLikes: newRealLikes, likedBy: newLb });
    if (!liked) {
        sendNotification(d.userId, 'like', {
            title: `${currentUser.name} liked your post`,
            body: d.text ? d.text.substring(0, 50) : '📸 Photo post',
            postId
        });
    }
    liked ? showToast('info', 'Unliked', 'Removed') : showToast('success', 'Liked!', 'Added');


    // Update just the like button in-place, no scroll jump
    const btn = document.querySelector(`.post-action-btn[data-postid="${postId}"][data-action="like"]`);
    if (btn) {
        const tl = (d.baseLikes || 0) + newRealLikes;
        btn.classList.toggle('liked', !liked);
        btn.querySelector('i').style.color = !liked ? '#ef4444' : '#94a3b8';
        btn.querySelector('span').textContent = formatCount(tl);
    }
}





