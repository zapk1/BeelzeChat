async function loadMessages() {
    const chatId = currentChatId;
    if (msgUnsub) { msgUnsub(); msgUnsub = null; }
    // Show cached messages INSTANTLY before Firestore responds
    const cached = getMsgs(chatId);
    if (cached.length) {
        renderMessages(cached);
        const mc = document.getElementById('messagesContainer');
        mc.scrollTop = mc.scrollHeight;
    }
    const unsub = db.collection('chats').doc(chatId).collection('messages').orderBy('timestamp', 'asc').onSnapshot(snap => {
        if (currentChatId !== chatId) return;
        const msgs = snap.docs.map(d => ({ id: d.id, ...d.data() }));
        
        // Skip re-render if messages haven't changed
        const oldMsgs = getMsgs(chatId);
        if (JSON.stringify(msgs) === JSON.stringify(oldMsgs)) return;
        
        saveMsgs(chatId, msgs);
        
        const mc = document.getElementById('messagesContainer');
        const wasAtBottom = mc.scrollHeight - mc.scrollTop - mc.clientHeight < 50;
        
        renderMessages(msgs);
        
        // Only scroll if user was at bottom (prevents jump)
        if (wasAtBottom) {
            mc.scrollTop = mc.scrollHeight;
        }
    });
    msgUnsub = unsub;
}

function renderMessages(messages) {
    const mc = document.getElementById('messagesContainer');
    const wasAtBottom = mc.scrollHeight - mc.scrollTop - mc.clientHeight < 100;
    mc.innerHTML = '';
    messages.forEach(msg => {
        const div = document.createElement('div');
        if (msg.isSystem) {
            div.style.cssText = 'text-align:center;padding:4px 0;';
            div.innerHTML = `<span style="background:#f1f5f9;color:#64748b;font-size:12px;font-weight:600;padding:4px 12px;border-radius:20px;">${msg.text}</span>`;
            mc.appendChild(div);
            return;
        }
        div.className = `message ${msg.senderId === currentUser.id ? 'own' : 'other'}`;
        const time = new Date(msg.timestamp).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        const av = msg.senderAvatar ?
            `<img src="${msg.senderAvatar}" style="width:100%;height:100%;object-fit:cover;">` :
