function calcMktViews(listing) {
    const hrs = (Date.now() - (listing.createdAt || Date.now())) / 3600000;
    const factor = Math.min(1, hrs / 72);
    return Math.floor((listing.baseViews || 1000) * Math.max(0.05, factor)) + (listing.realViews || 0);
}
function calcMktLikes(listing) {
    return Math.floor(calcMktViews(listing) * 0.18) + (listing.realLikes || 0);
}

