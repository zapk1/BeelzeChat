                <div style="font-size:12px;color:#64748b;">${seller.identifier || ''}</div>
            </div>
            ${listing.sellerId !== currentUser?.id 
    ? `<button id="pdMsgBtn" style="background:#3b82f6;color:white;border:none;border-radius:10px;padding:10px 14px;font-weight:700;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:6px;"><i data-lucide="message-circle" style="width:16px;height:16px;color:white;"></i>Message</button>` 
    : `<button id="pdDeleteBtn" style="background:#ef4444;color:white;border:none;border-radius:10px;padding:10px 14px;font-weight:700;font-size:13px;cursor:pointer;display:flex;align-items:center;gap:6px;"><i data-lucide="trash-2" style="width:16px;height:16px;color:white;"></i>Delete</button>`
}
        </div>
        ${contactRows ? `<div style="display:flex;flex-direction:column;gap:8px;">${contactRows}</div>` : ''}
        <div style="display:flex;align-items:center;gap:14px;">
            <button id="pdLikeBtn" style="display:flex;align-items:center;gap:8px;padding:12px 20px;border:2px solid ${liked?'#ef4444':'#e2e8f0'};border-radius:12px;background:${liked?'#fff1f2':'white'};cursor:pointer;font-weight:800;font-size:15px;">
                <i data-lucide="heart" style="width:20px;height:20px;color:${liked?'#ef4444':'#94a3b8'};${liked?'fill:#ef4444;':''}"></i>
                <span style="color:#ef4444;">${formatCount(dl)}</span>
            </button>
            <div style="display:flex;align-items:center;gap:6px;color:#64748b;font-size:13px;">
                <i data-lucide="eye" style="width:16px;height:16px;"></i>${formatCount(dv)} views
            </div>
        </div>
    `;
    content.querySelector('#pdLikeBtn')?.addEventListener('click', () => toggleListingLike(listing.id));
    content.querySelector('#pdMsgBtn')?.addEventListener('click', () => contactSellerFromMarket(listing.sellerId, listing.title, listing.id));
content.querySelector('#pdDeleteBtn')?.addEventListener('click', async () => {
    if (!confirm('Delete this listing? This cannot be undone.')) return;
    await db.collection('marketplace').doc(listing.id).delete();
    document.getElementById('productDetailView').style.display = 'none';
    showToast('success', 'Deleted', 'Your listing has been removed');
    loadMarketplace();
});
    content.querySelector('#pdSellerRow')?.addEventListener('click', () => {
        document.getElementById('productDetailView').style.display = 'none';
        document.getElementById('marketplaceView').classList.remove('active');
        document.getElementById('app').classList.add('active');
        showUserProfile(listing.sellerId, allUsers[listing.sellerId] || { name: listing.sellerName });
    });
    if (imgs.length > 1) {
        let cs = 0;
        const slider = content.querySelector('#pSlider');
        const dots = content.querySelectorAll('.pdot');
        const goTo = i => { cs = i; slider.style.transform = `translateX(-${i*100}%)`; dots.forEach((d,j) => d.style.background = j===i?'#3b82f6':'#e2e8f0'); };
        dots.forEach(d => d.addEventListener('click', () => goTo(+d.dataset.idx)));
        let sx = 0;
        slider.addEventListener('touchstart', e => sx = e.touches[0].clientX, { passive: true });
        slider.addEventListener('touchend', e => {
            const diff = sx - e.changedTouches[0].clientX;
            if (Math.abs(diff) > 50) { if (diff > 0 && cs < imgs.length-1) goTo(cs+1); else if (diff < 0 && cs > 0) goTo(cs-1); }
        });
    }
    lucide.createIcons();
}

async function toggleListingLike(listingId) {
    const ref = db.collection('marketplace').doc(listingId);
    const snap = await ref.get();
    if (!snap.exists) return;
    const d = snap.data();
    const lb = d.likedBy || [];
    const liked = lb.includes(currentUser.id);
    const newLb = liked ? lb.filter(i => i !== currentUser.id) : [...lb, currentUser.id];
    const newRealLikes = liked ? Math.max((d.realLikes||1)-1, 0) : (d.realLikes||0)+1;
    await ref.update({ likedBy: newLb, realLikes: newRealLikes });
    const newLiked = !liked;
    const updatedListing = { ...d, likedBy: newLb, realLikes: newRealLikes };
    const newDl = calcMktLikes(updatedListing);
    // Update card in grid
    const cardBtn = document.querySelector(`.mkt-like-btn[data-id="${listingId}"]`);
    if (cardBtn) {
        cardBtn.querySelector('i').style.color = newLiked ? '#ef4444' : '#94a3b8';
        cardBtn.querySelector('i').style.fill = newLiked ? '#ef4444' : 'none';
        cardBtn.querySelector('span').textContent = formatCount(newDl);
    }
    // Update product detail like button if open
    const pdBtn = document.getElementById('pdLikeBtn');
    if (pdBtn) {
        pdBtn.style.borderColor = newLiked ? '#ef4444' : '#e2e8f0';
        pdBtn.style.background = newLiked ? '#fff1f2' : 'white';
        pdBtn.querySelector('i').style.color = newLiked ? '#ef4444' : '#94a3b8';
        pdBtn.querySelector('i').style.fill = newLiked ? '#ef4444' : 'none';
        pdBtn.querySelector('span').textContent = formatCount(newDl);
    }
}

// Sell modal
document.getElementById('sellBtn').addEventListener('click', () => {
    document.getElementById('sellWhatsapp').value = currentUser?.phone || '';
    document.getElementById('sellEmail').value = currentUser?.email || currentUser?.identifier || '';
    document.getElementById('sellWebsite').value = currentUser?.website || '';
    document.getElementById('sellTitle').value = '';
    document.getElementById('sellDescription').value = '';
    document.getElementById('sellPrice').value = '';
    document.getElementById('sellHashtags').value = '';
    sellImages = [];
    renderSellImagesPreview();
    document.getElementById('sellModal').classList.add('active');
    lucide.createIcons();
});
document.getElementById('closeSellModal').addEventListener('click', () => document.getElementById('sellModal').classList.remove('active'));

document.getElementById('sellImagesInput').addEventListener('change', async e => {
    const files = Array.from(e.target.files);
    if (sellImages.filter(i=>i!=='__loading__').length + files.length > 5) { showToast('error','Max 5','Maximum 5 images allowed'); e.target.value=''; return; }
    for (const f of files) {
        const idx = sellImages.length;
        sellImages.push('__loading__');
        renderSellImagesPreview();
        const url = await uploadToImgBB(f);
        if (url) sellImages[idx] = url; else sellImages.splice(idx,1);
        renderSellImagesPreview();
    }
    e.target.value = '';
});

function renderSellImagesPreview() {
    const p = document.getElementById('sellImagesPreview');
    p.style.cssText = 'display:flex;gap:8px;flex-wrap:wrap;padding:8px 0;';
    p.innerHTML = '';
    sellImages.forEach((img, i) => {
        const w = document.createElement('div');
        w.style.cssText = 'position:relative;width:80px;height:80px;flex-shrink:0;border-radius:10px;overflow:hidden;';
        if (img === '__loading__') {
            w.innerHTML = `<div style="width:80px;height:80px;background:#f1f5f9;border-radius:10px;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:4px;border:2px dashed #cbd5e1;"><div style="width:18px;height:18px;border:3px solid #3b82f6;border-top-color:transparent;border-radius:50%;animation:spin .8s linear infinite;"></div><span style="font-size:9px;color:#64748b;font-weight:700;">Uploading</span></div>`;
        } else {
            w.innerHTML = `<img src="${img}" style="width:80px;height:80px;object-fit:cover;border-radius:10px;display:block;"><button type="button" style="position:absolute;top:-6px;right:-6px;width:22px;height:22px;background:#ef4444;color:white;border:none;border-radius:50%;cursor:pointer;font-size:14px;font-weight:900;line-height:22px;text-align:center;padding:0;" data-index="${i}">×</button>`;
            w.querySelector('button').addEventListener('click', () => { sellImages.splice(i,1); renderSellImagesPreview(); });
        }
        p.appendChild(w);
    });
}

document.getElementById('sellForm').addEventListener('submit', async e => {
    e.preventDefault();
    const title = document.getElementById('sellTitle').value.trim();
    const price = document.getElementById('sellPrice').value.trim();
    if (!title || !price) { showToast('error','Required','Title and price are required'); return; }
    if (sellImages.some(i=>i==='__loading__')) { showToast('error','Wait','Images still uploading'); return; }
    showToast('info','Listing...','Creating your listing');
    const bv = Math.floor(Math.random()*(8000-800)+800);
    await db.collection('marketplace').add({
        title, price,
        description: document.getElementById('sellDescription').value.trim(),
        hashtags: document.getElementById('sellHashtags').value.trim(),
        whatsapp: document.getElementById('sellWhatsapp').value.trim(),
        email: document.getElementById('sellEmail').value.trim(),
        website: document.getElementById('sellWebsite').value.trim(),
        images: [...sellImages],
        sellerId: currentUser.id, sellerName: currentUser.name,
        createdAt: Date.now(),
        baseViews: bv, baseLikes: Math.floor(bv*0.18),
        realViews: 0, realLikes: 0, likedBy: []
    });
    showToast('success','Listed! 🛒','Your item is now live on Beelze Marketplace');
    document.getElementById('sellModal').classList.remove('active');
    sellImages = [];
    loadMarketplace();
});

document.getElementById('marketSearch').addEventListener('input', function() {
    const term = this.value.toLowerCase();
    document.querySelectorAll('#marketplaceGrid > div').forEach(card => {
        card.style.display = card.textContent.toLowerCase().includes(term) ? '' : 'none';
    });
});







// Android back button handler
window.addEventListener('popstate', (e) => {
    e.preventDefault();
    // If chat is open, close it
    if (document.getElementById('chatView')?.classList.contains('active')) {
        document.getElementById('closeChatBtn').click();
    }
    // If any modal is open, close it
    else if (document.querySelector('.modal.active, [class*="Modal"][style*="flex"], [class*="Modal"].active')) {
        document.querySelectorAll('.modal.active').forEach(m => m.classList.remove('active'));
        document.querySelectorAll('[id*="Modal"][style*="flex"]').forEach(m => m.style.display = 'none');
    }
    // Always push a new state so back button never exits
    history.pushState(null, '', window.location.href);
});

// Push initial state
history.pushState(null, '', window.location.href);



