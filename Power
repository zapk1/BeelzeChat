    <style>
        * { 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
        }
        
        body { 
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; 
            background: #f8fafc; 
            overflow: hidden; 
            color: #0f172a; 
        }
        
    .auth-screen { 
    height: 100vh; 
    display: flex; 
    align-items: center; 
    justify-content: center; 
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
}
        
        .auth-container { 
            background: white; 
            padding: 48px 40px; 
            border-radius: 24px; 
            box-shadow: 0 25px 50px -12px rgba(0,0,0,0.15); 
            width: 90%; 
            max-width: 420px; 
            max-height: 90vh; 
            overflow-y: auto; 
            position: relative; 
            border: 2px solid #e2e8f0; 
        }
        
 @keyframes spin { to { transform: rotate(360deg); } }


       
  @keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}

.loading-spinner {
    animation: spin 1s linear infinite;
}
        
        
        .loading-screen {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    pointer-events: all;
    z-index: 999999;
}

.loading-screen.hide {
    opacity: 0;
    pointer-events: none;
}

/* ===== LOADING SCREEN - Smaller logo, thinner title ===== */
.loading-logo-img {
    width: 100px !important;
    height: 100px !important;
    border-radius: 14px;
}

.loading-title {
    font-size: 19px !important;
    font-weight: 800 !important;
    letter-spacing: 3px;
    color: #FFFFFF;
}

/* ===== SEARCH BARS - Gradient blue (People & Posts tabs) ===== */
#userSearch,
#postSearch {
    border: 2px solid transparent !important;
    background-image: linear-gradient(white, white), linear-gradient(135deg, #38bdf8, #3b82f6) !important;
    background-origin: border-box !important;
    background-clip: padding-box, border-box !important;
}

/* ===== CREATE POST MODAL - Rounded corners ===== */
.post-textarea {
    border-radius: 16px !important;
}
#postCategory {
    border-radius: 12px !important;
}
label[for="postImagesInput"].upload-btn {
    border-radius: 12px !important;
}

        .loading-spinner {
            width: 50px;
            height: 50px;
            border: 4px solid #e2e8f0;
            border-top-color: #06b6d4;
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        .loading-text {
            font-size: 16px;
            color: #FFFFFF;
            font-weight: 600;
        }

        .loading-subtext {
            font-size: 15px;
            color: #FFFFFF;
            text-align: center;
            max-width: 340px;
            line-height: 1.6;
            padding: 0 20px;
        }

        
        
        
        
        
        
