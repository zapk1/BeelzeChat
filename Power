async function loadNotifications() {
    if (!currentUser) return;
    if (notifUnsub) { notifUnsub(); notifUnsub = null; }
    const fiveDaysAgo = Date.now() - (5 * 24 * 60 * 60 * 1000);

    notifUnsub = db.collection('users').doc(currentUser.id).collection('notifications')
        .orderBy('timestamp', 'desc')
        .limit(50)
        .onSnapshot(snap => {
            const notifs = snap.docs.map(d => ({ id: d.id, ...d.data() }));

            // Delete old ones automatically
            snap.docs.forEach(d => {
                if (d.data().timestamp < fiveDaysAgo) d.ref.delete();
            });

            const unread = notifs.filter(n => !n.read).length;
            const badge = document.getElementById('notifBadge');
            if (unread > 0) {
                badge.textContent = unread > 99 ? '99+' : unread;
                badge.style.display = 'block';
            } else {
                badge.style.display = 'none';
            }

            const list = document.getElementById('notifList');
            if (!notifs.length) {
                list.innerHTML = '<div style="text-align:center;color:#94a3b8;padding:30px;font-size:14px;">No notifications yet</div>';
                return;
            }

            list.innerHTML = notifs.map(n => {
                const iconMap = { like: 'heart', comment: 'message-circle', message: 'message-square', view: 'eye', group_added: 'users' };
                const iconName = iconMap[n.type] || 'bell';
                const icon = `<i data-lucide="${iconName}" style="width:16px;height:16px;color:#3b82f6;"></i>`;

                const time = getTimeAgo(n.timestamp);
                const senderPic = n.senderPic || `https://ui-avatars.com/api/?name=${encodeURIComponent(n.senderName||'U')}&background=000&color=fff&size=64`;
                return `
                    <div onclick="handleNotifClick('${n.id}','${n.type}','${n.postId||''}','${n.senderId||''}')" style="display:flex;align-items:center;gap:12px;padding:12px;background:${n.read?'#f8fafc':'#eff6ff'};border-radius:14px;cursor:pointer;border:1px solid ${n.read?'#e2e8f0':'#bfdbfe'};">
                        <div style="position:relative;flex-shrink:0;">
                            <img src="${senderPic}" style="width:44px;height:44px;border-radius:50%;object-fit:cover;">
                            <span style="position:absolute;bottom:-2px;right:-2px;background:white;border-radius:50%;width:20px;height:20px;display:flex;align-items:center;justify-content:center;">${icon}</span>
                        </div>
                        <div style="flex:1;min-width:0;">
                            <div style="font-weight:700;font-size:13px;color:#0f172a;">${n.title||'Notification'}</div>
                            <div style="font-size:12px;color:#64748b;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${n.body||''}</div>
                            <div style="font-size:11px;color:#94a3b8;margin-top:2px;">${time}</div>
                        </div>
                    </div>`;
            }).join('');
            lucide.createIcons();
        });
}

async function handleNotifClick(notifId, type, postId, senderId) {
    // Mark as read
    await db.collection('users').doc(currentUser.id).collection('notifications').doc(notifId).update({ read: true });
    document.getElementById('notificationsModal').style.display = 'none';

    if ((type === 'like' || type === 'comment') && postId) {
        // Go to Posts tab and scroll to post
        document.querySelectorAll('.nav-item').forEach(i => i.classList.remove('active'));
        document.querySelectorAll('.nav-item')[3]?.classList.add('active');
