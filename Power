        URL.revokeObjectURL(blobUrl);
        showToast('success', 'Downloaded!', 'Check your Downloads folder');
    } catch(e) {
        // Method 2: Open in new tab (iPhone/CORS block fallback)
        window.open(url, '_blank');
        showToast('info', 'iPhone Tip', 'Hold the image → tap "Add to Photos"');
    }
});

