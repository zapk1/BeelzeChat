                ${unread > 0 ? `<div style="display:flex;flex-direction:column;align-items:center;gap:1px;"><div class="unread-badge" style="background:#ef4444;">${unread > 99 ? '99+' : unread}</div><div style="font-size:8px;font-weight:900;color:#ef4444;">NEW</div></div>` : ''}
            `;
            div.onclick = () => openChat(chat.id, other, oid);
            if (oid && !allUsers[oid]) {
                db.collection('users').doc(oid).get().then(ud => {
                    if (ud.exists) { allUsers[oid] = ud.data(); renderChatsList(docs); }
                });
            }
